# ═══════════════════════════════════════════════════════════════════════════
# 🐙 VANTUZ AI v3.1 - Yapılandırma Dosyası
# Bu dosyayı ~/.vantuz/.env olarak kopyalayın
# ═══════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════
# AI SAĞLAYICI (birini seçin)
# ═══════════════════════════════════════════════════════════════════════════

# Gemini (önerilen - ücretsiz)
GEMINI_API_KEY=

# Groq (hızlı - ücretsiz)
GROQ_API_KEY=

# OpenAI (GPT-4)
OPENAI_API_KEY=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════
# PAZARYERI API'LERİ
# ═══════════════════════════════════════════════════════════════════════════

# 🟠 TRENDYOL
# developers.trendyol.com üzerinden alınır
TRENDYOL_SUPPLIER_ID=
TRENDYOL_API_KEY=
TRENDYOL_API_SECRET=

# 🟣 HEPSİBURADA
HEPSIBURADA_MERCHANT_ID=
HEPSIBURADA_USERNAME=
HEPSIBURADA_PASSWORD=

# 🔵 N11
HEPSIBURADA_MERCHANT_ID=
N11_API_KEY=
N11_API_SECRET=

# 🟡 AMAZON
# Amazon SP-API (Selling Partner API)
AMAZON_SELLER_ID=
AMAZON_CLIENT_ID=
AMAZON_CLIENT_SECRET=
AMAZON_REFRESH_TOKEN=

# 🌸 ÇİÇEKSEPETİ
CICEKSEPETI_API_KEY=

# 📮 PTTAVM
PTTAVM_API_KEY=
PTTAVM_TOKEN=

# 🛒 PAZARAMA
PAZARAMA_CLIENT_ID=
PAZARAMA_CLIENT_SECRET=

# ═══════════════════════════════════════════════════════════════════════════
# İLETİŞİM KANALLARI
# ═══════════════════════════════════════════════════════════════════════════

# 📱 WHATSAPP (Meta Business API)
# developers.facebook.com/docs/whatsapp/cloud-api
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# ✈️ TELEGRAM BOT
# @BotFather ile oluşturun
TELEGRAM_BOT_TOKEN=

# ═══════════════════════════════════════════════════════════════════════════
# LİSANS
# ═══════════════════════════════════════════════════════════════════════════

VANTUZ_LICENSE_KEY=

# ═══════════════════════════════════════════════════════════════════════════
# GELİŞMİŞ AYARLAR (Opsiyonel)
# ═══════════════════════════════════════════════════════════════════════════

# Webhook URL (siparişleri almak için)
WEBHOOK_URL=

# Minimum kar marjı (%)
MIN_PROFIT_MARGIN=15

# Düşük stok uyarı eşiği
LOW_STOCK_THRESHOLD=5
